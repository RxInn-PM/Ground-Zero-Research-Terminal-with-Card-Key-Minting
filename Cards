<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CERNEL//FORGE — Infinite Procedural Card Set</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap');

:root {
  /* CLASH palette */
  --overshoot-p: #ff2200;
  --overshoot-s: #ff8844;
  --deadlock-p:  #8855ff;
  --deadlock-s:  #ccaaff;
  --bloom-p:     #00ff88;
  --bloom-s:     #88ffcc;

  /* CONDUIT palette */
  --relay-p:   #00ccff;
  --relay-s:   #0066aa;
  --vector-p:  #ffdd00;
  --vector-s:  #aa8800;
  --cluster-p: #ff0077;
  --cluster-s: #880044;

  --bg:    #020407;
  --bg2:   #050a0f;
  --g:     #00ff88;
  --gdim:  #002211;
  --gmid:  #005533;
  --border:rgba(0,255,136,0.12);
}

*{margin:0;padding:0;box-sizing:border-box;}
html,body{background:var(--bg);color:var(--g);font-family:'Share Tech Mono',monospace;font-size:12px;min-height:100vh;overflow-x:hidden;cursor:none;}

/* CRT */
body::before{content:'';position:fixed;inset:0;z-index:9999;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent 0,transparent 2px,rgba(0,0,0,.12) 2px,rgba(0,0,0,.12) 4px);}
body::after{content:'';position:fixed;inset:0;z-index:9998;pointer-events:none;
  background:radial-gradient(ellipse at 50% 0%,transparent 50%,rgba(0,0,0,.65) 100%);}

/* CURSOR */
#cur{position:fixed;width:9px;height:16px;background:var(--g);pointer-events:none;z-index:10000;
  animation:blink 1s step-end infinite;box-shadow:0 0 8px var(--g),0 0 18px rgba(0,255,136,.3);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

/* ── HEADER ─────────────────────────────────── */
#header{
  position:sticky;top:0;z-index:500;
  background:var(--bg2);border-bottom:1px solid var(--border);
  padding:10px 20px 8px;
}
.hrow1{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:8px;}
.logo{font-family:'Orbitron',sans-serif;font-weight:900;font-size:20px;
  color:var(--g);text-shadow:0 0 14px var(--g),0 0 32px rgba(0,255,136,.25);letter-spacing:5px;}
.logo em{color:var(--relay-p);font-style:normal;text-shadow:0 0 12px var(--relay-p);}
.logo small{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--gmid);letter-spacing:3px;display:block;}

.chip{padding:2px 7px;border:1px solid currentColor;font-size:9px;letter-spacing:2px;}
.chip-g{color:var(--g)}.chip-r{color:var(--overshoot-p)}.chip-c{color:var(--relay-p)}.chip-y{color:var(--vector-p)}.chip-v{color:var(--deadlock-p)}

/* CONTROLS ROW */
.hrow2{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ctrl-group{display:flex;gap:4px;align-items:center;padding-right:12px;border-right:1px solid var(--gdim);}
.ctrl-group:last-child{border-right:none;}
.ctrl-label{font-size:9px;color:var(--gmid);letter-spacing:2px;white-space:nowrap;}

.btn{
  padding:4px 12px;border:1px solid;font-family:'Share Tech Mono',monospace;font-size:10px;
  cursor:pointer;background:transparent;letter-spacing:1px;transition:all .12s;white-space:nowrap;
}
.btn-g{color:var(--gmid);border-color:var(--gmid);}
.btn-g:hover{color:var(--g);border-color:var(--g);box-shadow:0 0 8px var(--g);background:rgba(0,255,136,.04);}
.btn-r{color:#440800;border-color:#440800;}
.btn-r:hover{color:var(--overshoot-p);border-color:var(--overshoot-p);box-shadow:0 0 8px var(--overshoot-p);}
.btn-c{color:#004455;border-color:#004455;}
.btn-c:hover{color:var(--relay-p);border-color:var(--relay-p);box-shadow:0 0 8px var(--relay-p);}
.btn-v{color:#220044;border-color:#220044;}
.btn-v:hover{color:var(--deadlock-p);border-color:var(--deadlock-p);box-shadow:0 0 8px var(--deadlock-p);}
.btn-y{color:#332200;border-color:#332200;}
.btn-y:hover{color:var(--vector-p);border-color:var(--vector-p);box-shadow:0 0 8px var(--vector-p);}

/* TYPE BTNS */
.type-btn{
  padding:3px 9px;border:1px solid;font-family:'Share Tech Mono',monospace;font-size:9px;
  cursor:pointer;background:transparent;letter-spacing:2px;transition:all .12s;
}
.type-btn.on{background:rgba(255,255,255,.07);}
.tb-ov{color:#ff4411;border-color:#ff2200;} .tb-ov.on{box-shadow:0 0 6px var(--overshoot-p);}
.tb-dl{color:#9966ff;border-color:#8855ff;} .tb-dl.on{box-shadow:0 0 6px var(--deadlock-p);}
.tb-bl{color:#22ff88;border-color:#00ff88;} .tb-bl.on{box-shadow:0 0 6px var(--bloom-p);}
.tb-re{color:#11ccff;border-color:#00ccff;} .tb-re.on{box-shadow:0 0 6px var(--relay-p);}
.tb-ve{color:#ffcc00;border-color:#ffdd00;} .tb-ve.on{box-shadow:0 0 6px var(--vector-p);}
.tb-cl{color:#ff2288;border-color:#ff0077;} .tb-cl.on{box-shadow:0 0 6px var(--cluster-p);}

/* STATS */
.hstats{display:flex;gap:14px;font-size:9px;flex-wrap:wrap;align-items:center;}
.hs{color:var(--gmid)}.hs span{color:var(--g);}

/* SEED INPUT */
.seed-input{
  background:transparent;border:1px solid var(--gdim);color:var(--g);
  font-family:'Share Tech Mono',monospace;font-size:10px;padding:3px 8px;
  width:180px;letter-spacing:1px;outline:none;
}
.seed-input:focus{border-color:var(--g);}
.seed-input::placeholder{color:var(--gdim);}

/* ── SUBTYPE FILTER BAR ─────────────────────── */
#filter-bar{
  display:flex;gap:0;padding:6px 20px;border-bottom:1px solid var(--border);
  background:var(--bg2);overflow-x:auto;align-items:center;
}
.fb-label{font-size:9px;color:var(--gmid);letter-spacing:3px;margin-right:10px;white-space:nowrap;}
.fb-btn{
  padding:3px 10px;border:1px solid var(--gdim);color:var(--gmid);background:transparent;
  font-family:'Share Tech Mono',monospace;font-size:9px;cursor:pointer;letter-spacing:2px;
  margin-right:4px;transition:all .1s;white-space:nowrap;
}
.fb-btn:hover,.fb-btn.active{border-color:var(--g);color:var(--g);background:rgba(0,255,136,.05);}

/* ── CARD GRID ─────────────────────────────── */
#grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(190px,1fr));
  gap:14px;padding:16px 20px 40px;
}

/* ── NFT CARD ──────────────────────────────── */
.nft{
  position:relative;aspect-ratio:5/7;border-radius:3px;overflow:hidden;
  cursor:pointer;transition:transform .18s,filter .18s,box-shadow .18s;
  border:1px solid rgba(255,255,255,.06);
}
.nft:hover{transform:translateY(-5px) scale(1.025);filter:brightness(1.12);}
.nft svg{display:block;width:100%;height:100%;}

/* HOVER OVERLAY */
.nft-ov{
  position:absolute;inset:0;background:rgba(0,0,0,.8);opacity:0;
  transition:opacity .18s;display:flex;flex-direction:column;
  justify-content:flex-end;padding:12px;z-index:5;
}
.nft:hover .nft-ov{opacity:1;}
.nov-name{font-family:'VT323',monospace;font-size:20px;line-height:1;margin-bottom:3px;}
.nov-type{font-size:8px;letter-spacing:2px;opacity:.6;margin-bottom:6px;}
.nov-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;font-size:9px;margin-bottom:6px;}
.nov-k{color:var(--gmid)}.nov-v{color:var(--g);font-family:'VT323',monospace;font-size:12px;}
.nov-hash{font-size:7px;color:var(--gmid);word-break:break-all;margin-bottom:6px;}
.nov-btns{display:flex;gap:5px;}
.nov-btn{flex:1;padding:3px 0;border:1px solid;background:transparent;font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:1px;cursor:pointer;}

/* RARITY STRIP */
.rarity-strip{position:absolute;top:0;left:0;right:0;height:2px;z-index:3;}
.rarity-badge{
  position:absolute;top:6px;right:6px;z-index:4;
  padding:1px 5px;font-size:7px;letter-spacing:2px;border:1px solid currentColor;
  font-family:'Orbitron',sans-serif;font-weight:700;background:rgba(0,0,0,.6);
}
.type-badge{
  position:absolute;top:6px;left:6px;z-index:4;
  width:20px;height:20px;border-radius:2px;border:1px solid rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;font-size:12px;
  background:rgba(0,0,0,.5);
}
.minted-mark{
  position:absolute;bottom:42px;right:6px;z-index:4;
  font-size:8px;color:var(--g);opacity:0;transition:opacity .2s;
  font-family:'Share Tech Mono',monospace;letter-spacing:1px;
}
.nft.minted .minted-mark{opacity:1;}

/* ── MODAL ─────────────────────────────────── */
#modal{position:fixed;inset:0;z-index:8000;background:rgba(0,0,0,.9);
  display:none;align-items:center;justify-content:center;padding:16px;}
#modal.open{display:flex;}
#modal-box{
  background:var(--bg2);border:1px solid var(--border);
  max-width:600px;width:100%;border-radius:3px;overflow:hidden;
  display:grid;grid-template-columns:240px 1fr;max-height:90vh;
}
#m-art{background:var(--bg);display:flex;align-items:center;justify-content:center;padding:16px;min-height:280px;}
#m-art svg{width:200px;height:280px;}
#m-info{padding:16px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;}
.mi-h{font-family:'VT323',monospace;font-size:26px;line-height:1;}
.mi-sub{font-size:8px;color:var(--gmid);letter-spacing:3px;}
.mi-sec{font-size:8px;color:var(--gmid);letter-spacing:3px;border-bottom:1px solid var(--gdim);padding-bottom:2px;margin-top:4px;}
.mi-row{display:flex;justify-content:space-between;font-size:9px;}
.mi-k{color:var(--gmid)}.mi-v{font-family:'VT323',monospace;font-size:13px;}
.mi-hash-txt{font-size:7px;color:var(--gdim);word-break:break-all;line-height:1.7;margin-top:4px;}
.m-btn{padding:5px;border:1px solid;background:transparent;font-family:'Share Tech Mono',monospace;font-size:9px;cursor:pointer;letter-spacing:1px;transition:all .1s;}
.m-btn-mint{border-color:var(--g);color:var(--g);}
.m-btn-mint:hover{background:rgba(0,255,136,.07);}
.m-btn-close{border-color:var(--gdim);color:var(--gmid);}
.m-btn-close:hover{border-color:var(--g);color:var(--g);}

/* TOAST */
#toast{
  position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:9000;
  background:var(--bg2);border:1px solid var(--g);padding:8px 20px;
  font-size:10px;color:var(--g);display:none;letter-spacing:1px;
  box-shadow:0 0 20px rgba(0,255,136,.25);white-space:nowrap;
}

/* INFINITY LOADER */
#loader{
  text-align:center;padding:20px;color:var(--gmid);font-size:10px;letter-spacing:3px;display:none;
}

/* EMPTY */
#empty{text-align:center;padding:60px 20px;color:var(--gdim);display:none;}
#empty .e-logo{font-family:'VT323',monospace;font-size:36px;margin-bottom:8px;}
</style>
</head>
<body>

<div id="cur"></div>

<!-- HEADER -->
<div id="header">
  <div class="hrow1">
    <div>
      <div class="logo">CERN<em>EL</em>//FORGE</div>
      <div class="logo"><small>INFINITE PROCEDURAL CARD SET — ON-CHAIN SVG</small></div>
    </div>
    <div class="chip chip-r">CLASH</div>
    <div class="chip chip-c">CONDUIT</div>
    <div class="chip chip-g">∞ GEN</div>
    <div class="chip chip-v">ETH FORK</div>

    <div class="hstats">
      <span class="hs">CARDS: <span id="st-total">0</span></span>
      <span class="hs">MINTED: <span id="st-minted">0</span></span>
      <span class="hs">SEED: <span id="st-seed">—</span></span>
    </div>
  </div>

  <div class="hrow2">
    <div class="ctrl-group">
      <span class="ctrl-label">GENERATE//</span>
      <button class="btn btn-g" id="b-gen1">+1</button>
      <button class="btn btn-g" id="b-gen6">+6</button>
      <button class="btn btn-g" id="b-gen24">+24</button>
      <button class="btn btn-g" id="b-gen100">+100</button>
      <button class="btn btn-c" id="b-inf">∞ AUTO</button>
    </div>
    <div class="ctrl-group">
      <span class="ctrl-label">TYPE//</span>
      <button class="type-btn tb-ov on" data-t="OVERSHOOT">OVER</button>
      <button class="type-btn tb-dl on" data-t="DEADLOCK">DEAD</button>
      <button class="type-btn tb-bl on" data-t="BLOOM">BLOOM</button>
      <button class="type-btn tb-re on" data-t="RELAY">RELAY</button>
      <button class="type-btn tb-ve on" data-t="VECTOR">VECT</button>
      <button class="type-btn tb-cl on" data-t="CLUSTER">CLUST</button>
    </div>
    <div class="ctrl-group">
      <span class="ctrl-label">SEED//</span>
      <input class="seed-input" id="seed-input" placeholder="enter seed string..." />
      <button class="btn btn-y" id="b-seed">FORGE SEED</button>
    </div>
    <div class="ctrl-group">
      <button class="btn btn-c" id="b-mint-all">◈ MINT ALL</button>
      <button class="btn btn-y" id="b-export">↓ JSON</button>
      <button class="btn btn-r" id="b-clear">✕ CLEAR</button>
